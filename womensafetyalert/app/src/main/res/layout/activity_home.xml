<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/purple_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Top Navigation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="30dp">

            <TextView
                android:id="@+id/tvHome"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Home"/>

            <TextView
                android:id="@+id/tvAbout"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="About"/>

            <TextView
                android:id="@+id/tvvideos"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Videos"/>

            <TextView
                android:id="@+id/tvprofile"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Profile"/>
        </LinearLayout>

        <!-- Main Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NARIRAKSHA"
            android:textColor="#5E35B1"
            android:textStyle="bold"
            android:textSize="30sp"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Our system is designed to provide women with reliable and efficient way to call for help in emergency situations with real-time location tracking and instant alerts."
            android:textColor="#4A4A4A"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="30dp"/>

        <!-- Learn More Button -->
        <Button
            android:layout_width="200dp"
            android:id="@+id/btnLearnMore"
            android:layout_height="50dp"
            android:text="LEARN MORE"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:background="@drawable/btn_gradient"
            android:layout_gravity="center"
            android:layout_marginBottom="40dp"/>

        <!-- How It Works -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HOW IT WORKS"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#5E35B1"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Cards Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="40dp">

            <!-- Card 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="15dp"
                android:layout_margin="5dp"
                android:background="@drawable/card_light">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_dialog_alert"
                    android:layout_gravity="center"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Send Alert"
                    android:textStyle="bold"
                    android:textColor="#5E35B1"
                    android:gravity="center"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

            <!-- Card 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="15dp"
                android:layout_margin="5dp"
                android:background="@drawable/card_light">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_mylocation"
                    android:layout_gravity="center"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Track Location"
                    android:textStyle="bold"
                    android:textColor="#5E35B1"
                    android:gravity="center"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>

            <!-- Card 3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="15dp"
                android:layout_margin="5dp"
                android:background="@drawable/card_light">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_call"
                    android:layout_gravity="center"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Get Help"
                    android:textStyle="bold"
                    android:textColor="#5E35B1"
                    android:gravity="center"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Key Features -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="KEY FEATURES"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#5E35B1"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✔ 24/7 Support"
            android:textSize="16sp"
            android:textColor="#3F2B96"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✔ Fast Alerts"
            android:textSize="16sp"
            android:textColor="#3F2B96"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✔ Easy to Use"
            android:textSize="16sp"
            android:textColor="#3F2B96"/>

    </LinearLayout>
</ScrollView>