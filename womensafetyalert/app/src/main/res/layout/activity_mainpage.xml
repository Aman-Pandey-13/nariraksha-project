<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/purple_gradient">

    <!-- SINGLE ROOT LAYOUT INSIDE SCROLLVIEW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Top Navigation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="30dp">

            <TextView
                android:id="@+id/tvHome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Home"
                android:textStyle="bold"
                android:textColor="#3F2B96"/>

            <TextView
                android:id="@+id/tvAbout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="About"
                android:textColor="#3F2B96"/>

            <TextView
                android:id="@+id/tvVideos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Videos"
                android:textColor="#3F2B96"/>

            <TextView
                android:id="@+id/tvProfile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Profile"
                android:textColor="#3F2B96"/>

        </LinearLayout>

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NARIRAKSHA"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#3F2B96"
            android:gravity="center"
            android:layout_marginBottom="10dp"/>

        <!-- Subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ensuring safety and quick response for women in distress."
            android:textSize="16sp"
            android:textColor="#333333"
            android:gravity="center"
            android:layout_marginBottom="40dp"/>

        <!-- SOS BUTTON -->
        <FrameLayout
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center"
            android:background="@drawable/sos">

            <Button
                android:id="@+id/btnSOS"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="SOS"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textColor="#3F2B96"
                android:gravity="center"/>
        </FrameLayout>

        <!-- RECENT ACTIVITY TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recent Activity"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1F1F1F"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="16dp"/>

        <!-- ACTIVITY CARD -->
        <LinearLayout
            android:id="@+id/recentActivityContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/activity_card">

<!--            <TextView-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:text="10:32 AM  -  Alert sent to contacts"-->
<!--                android:textSize="16sp"-->
<!--                android:textColor="#3F2B96"-->
<!--                android:paddingBottom="8dp"/>-->

        </LinearLayout>

    </LinearLayout>

</ScrollView>