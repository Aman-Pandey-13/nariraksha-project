<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/purple_gradient">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top Navigation -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="40dp">

                <TextView
                    android:id="@+id/tvHome"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Home"/>

                <TextView
                    android:id="@+id/tvAbout"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="About"/>

                <TextView
                    android:id="@+id/tvVideos"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Videos"/>

                <TextView
                    android:id="@+id/tvprofile"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Profile"/>
            </LinearLayout>

            <!-- ABOUT Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ABOUT"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#6A1B9A"
                android:gravity="center"/>

            <!-- OUR MISSION -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OUR MISSION"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#5E35B1"
                android:gravity="center"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="20dp"/>

            <!-- Description -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="We are committed to enhancing the safety of women by providing a powerful and easy-to-use alert system. Our mission is to ensure that women can quickly call for help and share their location with trusted contacts and authorities in times of need."
                android:textSize="16sp"
                android:textColor="#4A4A4A"
                android:gravity="center"
                android:layout_marginBottom="40dp"/>

            <!-- BENEFITS -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BENEFITS"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#5E35B1"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

            <!-- Cards Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="40dp">

                <!-- Card 1 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_light"
                    android:padding="15dp"
                    android:layout_margin="5dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/checkbox_on_background"
                        android:layout_gravity="center"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Reliable Protection"
                        android:textStyle="bold"
                        android:textColor="#5E35B1"
                        android:gravity="center"
                        android:layout_marginTop="10dp"/>
                </LinearLayout>

                <!-- Card 2 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_light"
                    android:padding="15dp"
                    android:layout_margin="5dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_manage"
                        android:layout_gravity="center"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Advanced Technology"
                        android:textStyle="bold"
                        android:textColor="#5E35B1"
                        android:gravity="center"
                        android:layout_marginTop="10dp"/>
                </LinearLayout>

                <!-- Card 3 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_light"
                    android:padding="15dp"
                    android:layout_margin="5dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:layout_gravity="center"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="User-Friendly"
                        android:textStyle="bold"
                        android:textColor="#5E35B1"
                        android:gravity="center"
                        android:layout_marginTop="10dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- WHY CHOOSE US -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="WHY CHOOSE US?"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#5E35B1"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✔ Proven track record of enhancing women's safety"
                android:textSize="16sp"
                android:textColor="#3F2B96"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✔ Committed to privacy and confidentiality"
                android:textSize="16sp"
                android:textColor="#3F2B96"/>

        </LinearLayout>
    </ScrollView>

    <!-- Floating Circle Button -->
    <ImageButton
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:background="@drawable/btn_gradient"
        android:src="@android:drawable/ic_menu_help"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="20dp"
        android:scaleType="centerInside"/>

</RelativeLayout>